<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Kraken V2 Dashboard</title>
<style>
body { background:#111; color:#eee; font-family:sans-serif; margin:0; padding:20px; }
h1 { color:#4caf50; }
button { background:#4caf50; color:#111; border:none; padding:10px; margin:5px; cursor:pointer; }
.card { background:#222; margin:10px 0; padding:15px; border-radius:8px; }
.card h2 { color:#ffc107; margin:0 0 5px; }
.json-export { background:#444; padding:10px; margin-top:10px; white-space:pre; overflow-x:auto; }
</style>
</head>
<body>
<h1>Kraken V2 Dashboard</h1>
<input type="file" id="charts" multiple />
<button onclick="uploadCharts()">Analyser</button>
<button onclick="exportJSON()">Exporter JSON Fusionné</button>
<div id="results"></div>
<div id="jsonOutput" class="json-export"></div>

<script>
let allResults = [];

async function uploadCharts() {
  const files = document.getElementById("charts").files;
  if (!files.length) return alert("Choisis des fichiers !");
  const formData = new FormData();
  for (const file of files) formData.append("charts", file);
  const res = await fetch("/upload-charts", { method:"POST", body:formData });
  const data = await res.json();
  allResults = data.data;
  renderResults(allResults);
}

function renderResults(results) {
  const container = document.getElementById("results");
  container.innerHTML = "";
  results.forEach(r => {
    const div = document.createElement("div");
    div.className = "card";
    div.innerHTML = `
      <h2>${r.bias} - ${r.setup_valid ? "Validé ✅" : "❌"}</h2>
      <p>Prix actuel : ${r.current_price}</p>
      <p>Entry Zone : ${r.entry_zone.join(" - ")}</p>
      <p>Stop Loss : ${r.stop_loss} | TP : ${r.take_profit.join(" - ")}</p>
      <p>Risk/Reward : ${r.risk_reward} | Score : ${r.confidence_score}</p>
      <p>Justification : <br>
         Structure: ${r.justification.structure}<br>
         SMC: BOS=${r.justification.smc.BOS}, CHoCH=${r.justification.smc.CHoCH}<br>
         RSI divergence: ${r.justification.rsi.divergence}<br>
         CVD: ${r.justification.cvd.pression}
      </p>
      ${r.errors.length ? `<p style="color:#f44336">Erreurs: ${r.errors.join(", ")}</p>` : ""}
    `;
    container.appendChild(div);
  });
}

function exportJSON() {
  document.getElementById("jsonOutput").textContent = JSON.stringify(allResults, null, 2);
}
</script>
</body>
</html>
