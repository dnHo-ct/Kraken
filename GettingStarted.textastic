<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kraken Multi-Graph Interface – Premium</title>
<style>
  body { background: #0d1117; color: #c9d1d9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin:0; padding:20px;}
  h1 { text-align:center; color:#58a6ff; margin-bottom: 30px;}
  #uploadForm { display:flex; flex-direction:column; align-items:center; gap:10px; margin-bottom:20px;}
  input[type=file] { padding:8px; border-radius:5px; border:none; cursor:pointer; background:#161b22; color:#c9d1d9;}
  button { padding:10px 25px; border:none; border-radius:5px; cursor:pointer; font-weight:bold; transition:0.2s; }
  button#submitBtn { background:#238636; color:#fff; }
  button#submitBtn:hover { background:#2ea043; }
  button#exportJSON { background:#0969da; color:#fff; margin-top:20px; display:none;}
  button#exportJSON:hover { background:#218bff; }
  #progress { margin:15px 0; font-weight:bold; text-align:center; }
  .chart-card { background:#161b22; padding:15px; border-radius:8px; margin-bottom:15px; box-shadow:0 0 15px rgba(0,0,0,0.5);}
  .chart-card h3 { margin:0 0 8px 0; color:#79c0ff;}
  canvas { display:block; margin:10px auto; background:#0d1117; border:1px solid #30363d; border-radius:5px; }
  pre { background:#0d1117; padding:10px; border-radius:5px; overflow-x:auto; }
  .label { font-weight:bold; }
</style>
</head>
<body>

<h1>Kraken Multi-Graph Interface – Premium</h1>

<form id="uploadForm">
  <input type="file" id="charts" name="charts" multiple accept="image/*" />
  <button type="submit" id="submitBtn">Analyser les Graphiques</button>
</form>

<div id="progress">0 graphiques traités</div>
<div id="results"></div>
<button id="exportJSON">Exporter JSON Fusionné</button>

<script>
const uploadForm = document.getElementById("uploadForm");
const progress = document.getElementById("progress");
const resultsDiv = document.getElementById("results");
const exportBtn = document.getElementById("exportJSON");

let allResults = [];

uploadForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  resultsDiv.innerHTML = "";
  allResults = [];
  exportBtn.style.display = "none";

  const files = document.getElementById("charts").files;
  if (!files.length) return alert("Sélectionnez au moins un graphique.");

  progress.innerText = `0 / ${files.length} graphiques traités...`;

  const formData = new FormData();
  for (const file of files) formData.append("charts", file);

  const res = await fetch("/upload-charts", { method: "POST", body: formData });
  const data = await res.json();

  data.data.forEach((chart, idx) => {
    allResults.push(chart);

    const card = document.createElement("div");
    card.className = "chart-card";

    // Création du canvas pour l'image + zones
    const canvas = document.createElement("canvas");
    canvas.width = 600;
    canvas.height = 300;
    const ctx = canvas.getContext("2d");

    const img = new Image();
    img.src = chart.file ? `/uploads/${chart.file}` : '';
    img.onload = () => {
      ctx.drawImage(img,0,0,canvas.width,canvas.height);

      // Zones OB en rouge/vert
      ctx.fillStyle = chart.bias.toLowerCase() === "bullish" ? "rgba(0,255,0,0.25)" : "rgba(255,0,0,0.25)";
      ctx.fillRect(0, canvas.height - 50, canvas.width, 50);

      // Zone entrée Fibo
      ctx.fillStyle = "rgba(255,215,0,0.3)";
      ctx.fillRect(0, canvas.height - 100, canvas.width, 30);
    };

    card.innerHTML = `
      <h3>Graphique : ${chart.bias} - Score : ${chart.confidence_score}</h3>
      <p><span class="label">Biais:</span> ${chart.bias}</p>
      <p><span class="label">Entrée:</span> [${chart.entry_zone.join(", ")}], <span class="label">SL:</span> ${chart.stop_loss}, <span class="label">TP:</span> [${chart.take_profit.join(", ")}]</p>
      <p><span class="label">R/R:</span> ${chart.risk_reward}</p>
      <pre>${JSON.stringify(chart.justification, null, 2)}</pre>
      <p style="color:#f85149">${chart.errors.join("; ")}</p>
    `;
    card.appendChild(canvas);
    resultsDiv.appendChild(card);
    progress.innerText = `${idx+1} / ${files.length} graphiques traités...`;
  });

  exportBtn.style.display = "inline-block";
});

exportBtn.addEventListener("click", () => {
  const blob = new Blob([JSON.stringify(allResults, null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "decision_fusionnee.json";
  a.click();
  URL.revokeObjectURL(url);
});
</script>

</body>
</html>
